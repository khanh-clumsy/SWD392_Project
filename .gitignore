## .gitignore for modern .NET / ASP.NET Core projects

############################
# Build results
############################

[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
artifacts/

############################
# .NET Core
############################

project.lock.json
project.fragment.lock.json

############################
# ASP.NET Scaffolding
############################

ScaffoldingReadMe.txt

############################
# NuGet
############################

*.nupkg
*.snupkg
*.nuspec

# NuGet Packages folder
packages/

# NuGet v3 cache
*.nuget.props
*.nuget.targets

############################
# Test results
############################

[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
TestResults/
*.trx

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Code coverage
CodeCoverage/
coverage*.json
coverage*.xml

############################
# MSBuild
############################

*.binlog

############################
# User-specific files
############################

*.user
*.rsuser
*.suo
*.userosscache
*.sln.docstates

############################
# Visual Studio
############################

.vs/

############################
# Rider / JetBrains
############################

.idea/

############################
# VS Code
############################

.vscode/

############################
# OS generated files
############################

.DS_Store
Thumbs.db
ehthumbs.db

############################
# Temporary files
############################

~$*
*~
*.tmp
*.temp

############################
# Logs
############################

*.log

############################
# Environment files
############################

.env
.env.local

############################
# ASP.NET Core local settings
############################

appsettings.Development.json

############################
# Node (if using frontend tools)
############################

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
