@model SWD302_Project_HostelManagement.Models.Room

@{
    ViewData["Title"] = "Book Room";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a asp-controller="Tenant" asp-action="BookingRequestIndex">My Bookings</a>
                    </li>
                    <li class="breadcrumb-item active">Book Room</li>
                </ol>
            </nav>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-x-circle-fill me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Warning"] != null)
            {
                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Warning"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @* Room Info Card *@
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-house-door me-2"></i>Room Details
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-6">
                            <dl class="row mb-0">
                                <dt class="col-5">Hostel</dt>
                                <dd class="col-7">@Model.Hostel?.Name</dd>

                                <dt class="col-5">Room Number</dt>
                                <dd class="col-7"><strong>@Model.RoomNumber</strong></dd>

                                <dt class="col-5">Room Type</dt>
                                <dd class="col-7">@Model.RoomType</dd>

                                <dt class="col-5">Capacity</dt>
                                <dd class="col-7">@Model.Capacity person(s)</dd>
                            </dl>
                        </div>
                        <div class="col-sm-6">
                            <dl class="row mb-0">
                                <dt class="col-5">Area</dt>
                                <dd class="col-7">@Model.Area m²</dd>

                                <dt class="col-5">Floor</dt>
                                <dd class="col-7">@Model.Floor</dd>

                                <dt class="col-5">Price/Month</dt>
                                <dd class="col-7 text-success fw-bold">
                                    @Model.PricePerMonth.ToString("N0") VNĐ
                                </dd>

                                <dt class="col-5">Status</dt>
                                <dd class="col-7">
                                    <span class="badge bg-success">@Model.Status</span>
                                </dd>
                            </dl>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <hr />
                        <p class="mb-0 text-muted">
                            <i class="bi bi-info-circle me-1"></i>@Model.Description
                        </p>
                    }
                </div>
            </div>

            @* UC8 - Booking Form: TenantInteraction.submitBookingRequest *@
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-calendar-check me-2"></i>Submit Booking Request
                    </h5>
                </div>
                <div class="card-body">
                    @* UC8 - M2: POST → BookingCoordinator.submitBookingRequest *@
                    <form asp-controller="Tenant"
                          asp-action="BookRoom"
                          asp-route-roomId="@Model.RoomId"
                          method="post">
                        @Html.AntiForgeryToken()

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="checkIn" class="form-label fw-semibold">
                                    Check-in Date <span class="text-danger">*</span>
                                </label>
                                <input type="date"
                                       id="checkIn"
                                       name="checkIn"
                                       class="form-control"
                                       min="@DateTime.Today.ToString("yyyy-MM-dd")"
                                       required />
                                <div class="form-text">Select your move-in date.</div>
                            </div>

                            <div class="col-md-6">
                                <label for="checkOut" class="form-label fw-semibold">
                                    Check-out Date <span class="text-danger">*</span>
                                </label>
                                <input type="date"
                                       id="checkOut"
                                       name="checkOut"
                                       class="form-control"
                                       min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")"
                                       required />
                                <div class="form-text">Must be after check-in date.</div>
                            </div>
                        </div>

                        <div class="alert alert-info mt-3 mb-0" role="alert">
                            <i class="bi bi-envelope me-2"></i>
                            A confirmation email will be sent to your registered email address
                            after submission.
                        </div>

                        <div class="mt-4 d-flex gap-2">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-send me-1"></i>Submit Booking Request
                            </button>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Back
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        // UC8 pseudocode: IF data.checkOut <= data.checkIn THROW InvalidBookingDataException
        // Client-side validation để UX tốt hơn
        const checkInInput = document.getElementById('checkIn');
        const checkOutInput = document.getElementById('checkOut');

        checkInInput.addEventListener('change', function () {
            if (this.value) {
                const next = new Date(this.value);
                next.setDate(next.getDate() + 1);
                checkOutInput.min = next.toISOString().split('T')[0];
                if (checkOutInput.value && checkOutInput.value <= this.value) {
                    checkOutInput.value = '';
                }
            }
        });
    </script>
}
