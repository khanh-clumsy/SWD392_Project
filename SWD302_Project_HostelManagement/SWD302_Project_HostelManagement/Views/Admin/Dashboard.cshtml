@model SWD302_Project_HostelManagement.ViewModels.SystemStatisticsViewModel

@{
    ViewData["Title"] = "System Statistics Dashboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Thống kê hệ thống</h1>
        
        <div class="dropdown">
            <button class="btn btn-outline-secondary dropdown-toggle" type="button" id="timeFilterDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-calendar3 me-2"></i>
                @switch (Model.TimeFilter)
                {
                    case "Today": @:Hôm nay
                        break;
                    case "Last7Days": @:7 ngày qua
                        break;
                    case "Last30Days": @:30 ngày qua
                        break;
                    default: @:Tất cả thời gian
                        break;
                }
            </button>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="timeFilterDropdown">
                <li><a class="dropdown-item @(Model.TimeFilter == "All" ? "active" : "")" asp-action="Dashboard" asp-route-timeFilter="All">Tất cả thời gian</a></li>
                <li><a class="dropdown-item @(Model.TimeFilter == "Today" ? "active" : "")" asp-action="Dashboard" asp-route-timeFilter="Today">Hôm nay</a></li>
                <li><a class="dropdown-item @(Model.TimeFilter == "Last7Days" ? "active" : "")" asp-action="Dashboard" asp-route-timeFilter="Last7Days">7 ngày qua</a></li>
                <li><a class="dropdown-item @(Model.TimeFilter == "Last30Days" ? "active" : "")" asp-action="Dashboard" asp-route-timeFilter="Last30Days">30 ngày qua</a></li>
            </ul>
        </div>
    </div>

    <div class="row g-4">
        <!-- User Stats -->
        <div class="col-md-4 col-lg-3">
            <div class="card border-0 shadow-sm h-100 bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-2 opacity-75">Người dùng</h6>
                            <h2 class="mb-0">@Model.TotalUsers</h2>
                        </div>
                        <div class="fs-1 opacity-50">
                            <i class="bi bi-people"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Hostel Stats -->
        <div class="col-md-4 col-lg-3">
            <div class="card border-0 shadow-sm h-100 bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-2 opacity-75">Nhà trọ (Hostels)</h6>
                            <h2 class="mb-0">@Model.TotalHostels</h2>
                        </div>
                        <div class="fs-1 opacity-50">
                            <i class="bi bi-building"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Room Stats -->
        <div class="col-md-4 col-lg-3">
            <div class="card border-0 shadow-sm h-100 bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-2 opacity-75">Phòng (Rooms)</h6>
                            <h2 class="mb-0">@Model.TotalRooms</h2>
                        </div>
                        <div class="fs-1 opacity-50">
                            <i class="bi bi-door-open"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Booking Stats -->
        <div class="col-md-4 col-lg-3">
            <div class="card border-0 shadow-sm h-100 bg-warning text-dark">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-uppercase mb-2 opacity-75">Yêu cầu đặt phòng</h6>
                            <h2 class="mb-0">@Model.TotalBookings</h2>
                        </div>
                        <div class="fs-1 opacity-50">
                            <i class="bi bi-calendar-check"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0">Việc cần xử lý</h5>
                </div>
                <div class="list-group list-group-flush">
                    <a asp-action="Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3">
                        <div>
                            <i class="bi bi-house-door me-2 text-primary"></i>
                            Phê duyệt nhà trọ mới
                        </div>
                        @if (Model.PendingHostelRequests > 0)
                        {
                            <span class="badge bg-danger rounded-pill">@Model.PendingHostelRequests</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary rounded-pill">0</span>
                        }
                    </a>
                    <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                        <div>
                            <i class="bi bi-journal-check me-2 text-warning"></i>
                            Yêu cầu đặt phòng đang chờ
                        </div>
                        @if (Model.PendingBookingRequests > 0)
                        {
                            <span class="badge bg-warning rounded-pill">@Model.PendingBookingRequests</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary rounded-pill">0</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm bg-light">
                <div class="card-body p-5 text-center">
                    <i class="bi bi-graph-up text-muted display-1 mb-4"></i>
                    <h4>Thông tin thêm</h4>
                    <p class="text-muted">Tính năng biểu đồ tăng trưởng và xu hướng đang được phát triển.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
}
