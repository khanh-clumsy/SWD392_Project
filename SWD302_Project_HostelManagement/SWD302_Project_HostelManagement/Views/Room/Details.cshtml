@model SWD302_Project_HostelManagement.Models.Room
@{
    ViewData["Title"] = "Room Details";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="mb-1">Room @Model.RoomNumber</h2>
            <p class="text-muted mb-0">@Model.Hostel?.Name</p>
        </div>
        <span class="badge bg-success">@Model.Status</span>
    </div>

    <div class="row g-4">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h4 class="card-title mb-3">Room Information</h4>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <div class="text-muted small">Room ID</div>
                                <div class="fw-semibold">@Model.RoomId</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <div class="text-muted small">Price / Month</div>
                                <div class="fw-semibold">@Model.PricePerMonth.ToString("N0") VND</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <div class="text-muted small">Room Type</div>
                                <div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.RoomType) ? "Not specified" : Model.RoomType)</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <div class="text-muted small">Capacity</div>
                                <div class="fw-semibold">@(Model.Capacity?.ToString() ?? "Not specified")</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <div class="text-muted small">Area</div>
                                <div class="fw-semibold">@(Model.Area?.ToString("N0") ?? "Not specified") m2</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="border rounded p-3 bg-light">
                                <div class="text-muted small">Floor</div>
                                <div class="fw-semibold">@(Model.Floor?.ToString() ?? "Not specified")</div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <h5>Description</h5>
                        <p class="mb-0">@(string.IsNullOrWhiteSpace(Model.Description) ? "No description available." : Model.Description)</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h4 class="card-title mb-3">Hostel Information</h4>
                    <p class="mb-2"><strong>Name:</strong> @Model.Hostel?.Name</p>
                    <p class="mb-2"><strong>Address:</strong> @Model.Hostel?.Address</p>
                    <p class="mb-0"><strong>Base Price:</strong> @Model.Hostel?.Price.ToString("N0") VND</p>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <h4 class="card-title mb-3">Owner Contact</h4>
                    <p class="mb-2"><strong>Name:</strong> @Model.Owner?.Name</p>
                    <p class="mb-2"><strong>Email:</strong> @Model.Owner?.Email</p>
                    <p class="mb-0"><strong>Phone:</strong> @(string.IsNullOrWhiteSpace(Model.Owner?.PhoneNumber) ? "Not specified" : Model.Owner.PhoneNumber)</p>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Back to Room List</a>
    </div>
</div>
