@model SWD302_Project_HostelManagement.ViewModels.HostelCreateViewModel
@{
    ViewData["Title"] = "Thêm Hostel mới";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <h2>🏠 Thêm Hostel mới</h2>
            <p class="text-muted">
                Hostel sẽ được tạo với trạng thái <strong>Chờ duyệt</strong>
                và không hiển thị với Tenant cho đến khi Admin duyệt.
            </p>
            <hr />

            @if (!ViewData.ModelState.IsValid)
            {
            <div class="alert alert-danger">
                <div asp-validation-summary="All"></div>
            </div>
            }

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold"></label>
                    <input asp-for="Name" class="form-control"
                           placeholder="VD: Nhà trọ Bình Minh" maxlength="200" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Address" class="form-label fw-bold"></label>
                    <input asp-for="Address" class="form-control"
                           placeholder="VD: 123 Nguyễn Văn A, Quận 1, TP.HCM" />
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-bold"></label>
                    <textarea asp-for="Description" class="form-control" rows="4"
                              placeholder="Mô tả tiện ích, vị trí, đặc điểm hostel..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary px-4">
                        Gửi yêu cầu duyệt
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}