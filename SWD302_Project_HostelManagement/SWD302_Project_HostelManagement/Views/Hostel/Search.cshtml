@model HostelSearchPageViewModel
@{
    ViewData["Title"] = "Search Hostel";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Search Hostel</h2>
            <p class="text-muted mb-0">Tim hostel theo ten, dia chi va muc gia. Moi the se hien thi so phong trong hien tai.</p>
        </div>
        <span class="badge bg-dark fs-6">@Model.Results.Count hostel</span>
    </div>

    <form method="get" asp-controller="Hostel" asp-action="Search" class="card card-body shadow-sm mb-4">
        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="Filters.Keywords" class="form-label">Keywords</label>
                <input asp-for="Filters.Keywords" name="keywords" class="form-control" placeholder="Ten hostel, mo ta..." />
            </div>
            <div class="col-md-3">
                <label asp-for="Filters.Address" class="form-label">Address</label>
                <input asp-for="Filters.Address" name="address" class="form-control" placeholder="Quan, thanh pho..." />
            </div>
            <div class="col-md-2">
                <label asp-for="Filters.MinPrice" class="form-label">Min Price</label>
                <input asp-for="Filters.MinPrice" name="minPrice" class="form-control" min="0" step="1000" />
            </div>
            <div class="col-md-2">
                <label asp-for="Filters.MaxPrice" class="form-label">Max Price</label>
                <input asp-for="Filters.MaxPrice" name="maxPrice" class="form-control" min="0" step="1000" />
            </div>
            <div class="col-md-3">
                <label asp-for="Filters.Status" class="form-label">Status</label>
                <select asp-for="Filters.Status" name="status" class="form-select">
                    <option value="">All</option>
                    <option value="Approved">Approved</option>
                    <option value="PendingApproval">Pending Approval</option>
                    <option value="Rejected">Rejected</option>
                    <option value="Deleted">Deleted</option>
                </select>
            </div>
        </div>
        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Search</button>
            <a asp-controller="Hostel" asp-action="Search" class="btn btn-outline-secondary">Reset</a>
        </div>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="alert alert-warning">
            @Model.Message
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var hostel in Model.Results)
            {
                <div class="col-12">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h4 class="card-title mb-1">@hostel.Name</h4>
                                    <p class="text-muted mb-0">@hostel.Address</p>
                                </div>
                                <span class="badge bg-success">@hostel.AvailableRoomCount room(s) available</span>
                            </div>

                            <p class="card-text mb-3">@(string.IsNullOrWhiteSpace(hostel.Description) ? "No description available." : hostel.Description)</p>

                            <div class="row">
                                <div class="col-md-4">
                                    <div class="border rounded p-3 bg-light">
                                        <div class="text-muted small">Hostel ID</div>
                                        <div class="fw-semibold">@hostel.HostelId</div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="border rounded p-3 bg-light">
                                        <div class="text-muted small">Base Price</div>
                                        <div class="fw-semibold">@hostel.Price.ToString("N0") VND</div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="border rounded p-3 bg-light">
                                        <div class="text-muted small">Status</div>
                                        <div class="fw-semibold">@hostel.Status</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
